APP_NAME=Локальный RAG по документам
APP_ENVIRONMENT=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DATABASE_URL=postgresql+asyncpg://rag_user:rag_password@localhost:5432/corporate_rag
APP_DOCUMENTS_DIR=/mnt/c/Users/USER/Documents/corporate-archive
APP_EMBEDDING_SERVICE_URL=http://127.0.0.1:8010
APP_OPENAI_MODEL=gpt-4.1-mini
APP_OPENAI_API_KEY=<SECRET>
APP_TELEGRAM_BOT_TOKEN=<SECRET>
APP_ALLOWED_TELEGRAM_USER_IDS=123456789
APP_OPERATOR_TELEGRAM_USER_IDS=123456789
APP_REQUIRE_ALLOWLIST=true
APP_AUTO_APPLY_DB_MIGRATIONS=false
APP_RETRIEVAL_TOP_K=8
APP_RETRIEVAL_MAX_DOCUMENTS=3
APP_RETRIEVAL_MIN_CONFIDENCE=0.25
APP_CONVERSATION_HISTORY_MESSAGES=10
APP_API_BASE_URL=http://127.0.0.1:8000
APP_LOG_LEVEL=INFO
EMBEDDER_MODEL_ID=intfloat/multilingual-e5-small
EMBEDDER_QUANTIZATION=none
EMBEDDER_DIMENSIONS=384
EMBEDDER_DEVICE=cuda
EMBEDDER_HOST=127.0.0.1
EMBEDDER_PORT=8010
EMBEDDER_ALLOW_CPU_FALLBACK=true
